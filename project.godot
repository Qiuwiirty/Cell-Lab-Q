; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Cell Lab Lagiats"
run/main_scene="uid://d3otf0i44bpmq"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Game="*res://Misc/GAME.gd"

[file_customization]

folder_colors={
"res://Cells/": "gray",
"res://Cells/Cell script/": "red",
"res://Cells/Tscn file/": "yellow",
"res://Images/": "purple",
"res://Shaders/": "green",
"res://Sound and Music/": "pink"
}

[global_group]

Cells="Group that includes ALL variety of cells"

[rendering]

renderer/rendering_method="mobile"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
