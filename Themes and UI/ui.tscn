[sub_resource type="GDScript" id="GDScript_yxjur"]
resource_name = "frost_glass_blur"
script/source = "extends CheckBox
const frost_glass_shader = preload(\"uid://cf7qe01ckvr4s\")
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	if $\"../..\".material.shader:
		button_pressed = true
	else:
		button_pressed = false

func _on_toggled(toggled_on: bool) -> void:
	if toggled_on:
		$\"../..\".material.shader = frost_glass_shader
	else:
		$\"../..\".material.shader = null
"

[sub_resource type="GDScript" id="GDScript_a5680"]
resource_name = "use_math_lighting"
script/source = "extends CheckBox

func _ready() -> void:
	button_pressed = Game.use_math_lightning
func _on_toggled(toggled_on: bool) -> void:
	Game.use_math_lightning = toggled_on
"

[sub_resource type="GDScript" id="GDScript_7yarc"]
resource_name = "math_lighting"
script/source = "extends HBoxContainer
func _ready() -> void:
	$x.value = Game.math_lighting.x
	$y.value = Game.math_lighting.y
	$z.value = Game.math_lighting.z
	$w.value = Game.math_lighting.w
func _on_x_value_changed(value: float) -> void:
	Game.math_lighting.x = value

func _on_y_value_changed(value: float) -> void:
	Game.math_lighting.y = value

func _on_z_value_changed(value: float) -> void:
	Game.math_lighting.z = value

func _on_w_value_changed(value: float) -> void:
	Game.math_lighting.w = value
"

[sub_resource type="GDScript" id="GDScript_s1gou"]
resource_name = "brightness_mult"
script/source = "extends HBoxContainer
func _ready() -> void:
	$b.value = Game.brightness_mult
func _on_b_value_changed(value: float) -> void:
	Game.brightness_mult = value
"

[sub_resource type="GDScript" id="GDScript_i6rmi"]
resource_name = "use_voronoi"
script/source = "extends CheckBox
func _ready():
	button_pressed = Game.use_voronoi
func _on_toggled(toggled_on: bool) -> void:
	Game.use_voronoi = toggled_on
"

[sub_resource type="GDScript" id="GDScript_mk4ph"]
resource_name = "salinity"
script/source = "extends HBoxContainer
func _ready() -> void:
	$SpinBox.value = Game.salinity
func _on_spin_box_value_changed(value: float) -> void:
	Game.salinity = value
"

[sub_resource type="GDScript" id="GDScript_2cuuw"]
resource_name = "max_adhesion_length"
script/source = "extends HBoxContainer

func _ready() -> void:
